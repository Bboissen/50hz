{
  "name": "50hz",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.16.0"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "pnpm optimize:assets && tsc -b && vite build",
    "optimize:assets": "node scripts/optimize-runtime-assets.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test --grep @smoke",
    "test:e2e:startup": "playwright test --grep @startup",
    "test:e2e:full": "playwright test",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:e2e:gameplay": "playwright test --grep @gameplay",
    "test:e2e:ui": "playwright test --ui",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "sharp": "^0.35.1",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9"
  }
}
